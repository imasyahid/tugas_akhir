# Environment Configuration
# Copy file ini ke .env dan isi dengan value yang sesuai

# Server Port
PORT=3000

# JWT Secret (gunakan string yang panjang dan random untuk production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ML API Configuration
ML_API_URL=http://127.0.0.1:5501

# Database Configuration (optional - untuk future migration)
# DB_TYPE=mongodb
# DB_URL=mongodb://localhost:27017/diabetes_prediction
# DB_USER=
# DB_PASS=

# Email Configuration (untuk future notifications)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Node Environment
NODE_ENV=development
